# Copy to .env and adjust if this box's paths differ. Never commit .env.
#
# Loaded by systemd via EnvironmentFile= in csm-agent@.service. Every
# variable below is optional - if unset (or this file is missing entirely),
# host-agent/lib/Sessions.php falls back to the values shown here, so a
# fresh checkout with no .env behaves exactly as before this file existed.
#
# tests/.env.testing is the analogous file for the test suite - it points
# these same variables at an isolated tmux socket and a fixture claude
# binary instead of the real host session. See tests/run.sh.

# --- Real claude CLI binary (argv[0] must match this exactly) ---
CLAUDE_BIN=/home/andres/.local/bin/claude

# --- Root directory offered as "workdir" choices in the New Session form ---
WWW_ROOT=/home/andres/www

# --- tmux socket this agent drives (-S flag) ---
TMUX_SOCKET=/tmp/tmux-1000/default

# --- Where per-session sidecar metadata (workdir, spawned_at) is stored ---
SIDECAR_DIR=/run/user/1000/csm-sessions

# --- Seconds of inactivity before "Kill inactive" considers a session dead ---
CLEANUP_THRESHOLD_SECONDS=43200

# --- claude-quota binary (scrapes Claude Code's own /usage panel via a
# detached screen session - see the script itself for the mechanism).
# Optional: if unset/missing/non-executable, the "quota" action just
# returns ok=false and the UI footer shows "Quota unavailable". ---
CLAUDE_QUOTA_BIN=/home/andres/dotfiles/bin/claude-quota

# --- Where the last successful quota reading is cached. The scrape is
# slow (10-40s, it drives a real TUI), so this is reused across requests
# until QUOTA_CACHE_TTL_SECONDS elapses instead of re-running every time. ---
QUOTA_CACHE_FILE=/run/user/1000/csm-agent-quota-cache.json

# --- How long a cached quota reading is considered fresh, in seconds ---
QUOTA_CACHE_TTL_SECONDS=300

# --- Max seconds to let claude-quota run before giving up ---
QUOTA_TIMEOUT_SECONDS=90
