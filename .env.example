# Copy to .env and fill in real values. Never commit .env.

# --- Basic Auth (required) ---
BASIC_AUTH_USER=changeme
BASIC_AUTH_PASS=change-this-too

# --- Host UID/GID that owns the tmux server ---
# Run `id andres` on the host and confirm these match (uid, and the primary
# gid — NOT necessarily the same number).
APP_UID=1000
APP_GID=1001

# --- Host tmux socket ---
# Default tmux socket location is /tmp/tmux-<uid>. Confirm with:
#   echo $TMUX  (while attached to any session as andres)
# or: ls -la /tmp/tmux-*/
TMUX_SOCKET_DIR=/tmp/tmux-1000
TMUX_SOCKET=/tmp/tmux-1000/default

# --- Network binding ---
# Set this to the server's actual LAN IP (e.g. 192.168.1.50), never 0.0.0.0.
# Leave as 127.0.0.1 if you only intend to reach it via SSH tunnel or from
# the host itself.
BIND_ADDR=127.0.0.1
APP_PORT=8091
