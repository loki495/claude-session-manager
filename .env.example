# Copy to .env and fill in real values. Never commit .env.

# --- Basic Auth (required) ---
BASIC_AUTH_USER=changeme
BASIC_AUTH_PASS=change-this-too

# --- Host UID/GID for the container's non-root user ---
# APP_GID must match the group that owns the host agent's socket file
# (SocketGroup= in host-agent/systemd/csm-agent.socket, "andres" -> gid
# 1001 on this box) so the container can connect to it. APP_UID no longer
# needs to match a specific host user, since the container never touches
# tmux or the filesystem directly - only the agent socket.
APP_UID=1000
APP_GID=1001

# --- Host agent socket ---
# Must point at the real socket file created by host-agent/install.sh,
# normally $XDG_RUNTIME_DIR/csm-agent.sock (i.e. /run/user/<uid>/csm-agent.sock).
# The host agent MUST be installed and running before `docker compose up`,
# see README.md.
CSM_AGENT_SOCKET_HOST=/run/user/1000/csm-agent.sock

# --- Network binding ---
# Set this to the server's actual LAN IP (e.g. 192.168.1.50), never 0.0.0.0.
# Leave as 127.0.0.1 if you only intend to reach it via SSH tunnel or from
# the host itself.
BIND_ADDR=127.0.0.1
APP_PORT=8091
