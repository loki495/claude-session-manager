# Fixture config for the test suite (tests/run.sh). No secrets - safe to
# commit. Mirrors host-agent/.env.example's variables, but points every
# host-specific path at an isolated fixture instead of the real host
# session, so tests can never touch real tmux sessions or spawn a real
# claude process. See tests/run.sh for how this is loaded and cleaned up.

# --- Fixture "claude" binary: a symlink to /bin/cat, not the real CLI ---
# A plain symlink (not a shebang script) so argv[0] is preserved exactly
# like the real launcher at /home/andres/.local/bin/claude - required for
# find_claude_processes()'s argv[0] match in Sessions.php to work in tests.
CLAUDE_BIN=/home/andres/www/claude-session-manager/tests/fixtures/fake_claude

# --- Fixture www root, not the real ~/www ---
WWW_ROOT=/home/andres/www/claude-session-manager/tests/fixtures/www_root

# --- Isolated tmux socket = a completely separate tmux server, never the
# real one at /tmp/tmux-1000/default. tests/run.sh kill-servers this on
# exit (trap), which also kills every process it started. ---
TMUX_SOCKET=/tmp/csm-test-tmux/socket

# --- Isolated sidecar dir, removed by tests/run.sh on exit ---
SIDECAR_DIR=/tmp/csm-test-sidecars

# --- Short threshold so the cleanup test doesn't need to wait 12h ---
CLEANUP_THRESHOLD_SECONDS=2

# --- Fixture claude-quota script - never spins up a real screen/claude TUI ---
CLAUDE_QUOTA_BIN=/home/andres/www/claude-session-manager/tests/fixtures/fake_claude_quota

# --- Isolated quota cache (plus its .refreshing marker), removed by
# tests/run.sh on exit - never the real host cache ---
QUOTA_CACHE_FILE=/tmp/csm-test-quota/cache.json

# --- Short TTL/timeout so staleness and in-flight-refresh tests don't need
# to wait anywhere close to the real 5min/90s defaults ---
QUOTA_CACHE_TTL_SECONDS=2
QUOTA_TIMEOUT_SECONDS=5
